# Copy this file to .env and fill in your real SMTP details.
# Without this file, bookings work but NO emails are sent.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Singin Reservations <your-email@gmail.com>"
PORT=3001
